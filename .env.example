# Healthcare Analytics Automation Configuration
# Copy this file to .env and update with your settings

# ============================================
# Data Sources
# ============================================
DATA_SOURCE_PATH=./data/healthcare_data.csv
DATA_OUTPUT_PATH=./data/processed/

# ============================================
# Database Configuration (if using database)
# ============================================
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./data/healthcare_analytics.db
DATABASE_BACKUP_PATH=./backups/

# ============================================
# Report Configuration
# ============================================
REPORT_OUTPUT_DIR=./reports/
REPORT_ARCHIVE_DIR=./reports/archive/
REPORT_RETENTION_DAYS=90

# ============================================
# Email Configuration (for report distribution)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
REPORT_RECIPIENTS=admin@hospital.com,supervisor@hospital.com
REPORT_SENDER=analytics@hospital.com

# ============================================
# Quality Metrics Thresholds
# ============================================
READMISSION_THRESHOLD_PCT=8.0
ADVERSE_EVENT_THRESHOLD_PCT=2.0
MORTALITY_THRESHOLD_PCT=1.0
SATISFACTION_THRESHOLD=8.0
WAIT_TIME_THRESHOLD_MIN=30

# ============================================
# Alert Configuration
# ============================================
ENABLE_ALERTS=true
ALERT_RECIPIENTS=alerts@hospital.com
ALERT_SEVERITY_LEVELS=info,warning,critical

# ============================================
# Scheduler Configuration
# ============================================
SCHEDULER_TIMEZONE=UTC
SCHEDULER_WORKER_THREADS=5

# Daily ETL Job - runs at 2 AM
ETL_JOB_ENABLED=true
ETL_JOB_HOUR=02
ETL_JOB_MINUTE=00
ETL_JOB_DAY_OF_WEEK=*

# Weekly Report - runs Monday at 8 AM
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_HOUR=08
WEEKLY_REPORT_MINUTE=00
WEEKLY_REPORT_DAY_OF_WEEK=mon

# Monthly Financial Report - runs 1st of month at 9 AM
MONTHLY_REPORT_ENABLED=true
MONTHLY_REPORT_HOUR=09
MONTHLY_REPORT_MINUTE=00
MONTHLY_REPORT_DAY=1

# Model Retraining - runs every Sunday at 3 AM
MODEL_RETRAIN_ENABLED=true
MODEL_RETRAIN_HOUR=03
MODEL_RETRAIN_MINUTE=00
MODEL_RETRAIN_DAY_OF_WEEK=sun

# Quality Metrics Check - runs daily at 10 AM
QUALITY_CHECK_ENABLED=true
QUALITY_CHECK_HOUR=10
QUALITY_CHECK_MINUTE=00
QUALITY_CHECK_DAY_OF_WEEK=*

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/automation.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10

# ============================================
# Data Validation Rules
# ============================================
VALIDATE_COMPLETENESS_THRESHOLD_PCT=95
MIN_RECORDS_PER_BATCH=100
MAX_RECORDS_PER_BATCH=10000

# ============================================
# Performance & Optimization
# ============================================
ENABLE_DATA_CACHING=true
CACHE_EXPIRATION_HOURS=24
ENABLE_PARALLEL_PROCESSING=true
MAX_WORKERS=5

# ============================================
# Development/Testing
# ============================================
DEBUG_MODE=false
DRY_RUN_MODE=false
